# ── StudyBuddy Backend — Environment Template ─────────────────────────────────
# Copy this file to .env.dev (development) or .env.production (production)
# and fill in real values. NEVER commit real .env files to version control.
#
# Generate a secure SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"

ENVIRONMENT=dev

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL async connection string
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/studybuddy

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Must be at least 32 random characters, unique per environment
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Production example: ALLOWED_ORIGINS=["https://app.yourdomain.com"]
ALLOWED_ORIGINS=["http://localhost:5173"]

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE_MB=20
# Use an absolute path in production (e.g. /var/app/uploads)
UPLOAD_DIR=uploads

# ── Rate limiting ─────────────────────────────────────────────────────────────
API_RATE_LIMIT=120/minute
AUTH_RATE_LIMIT=20/minute
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
AI_EVENT_RATE_LIMIT=20/hour

# ── Redis (required for background worker) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY
LLM_MODEL=gpt-4o-mini

# ── Bootstrap / roles ─────────────────────────────────────────────────────────
# Comma-separated emails that receive the "developer" role on first registration.
# Leave empty to disable.
DEVELOPER_EMAILS=

# ── OAuth (optional — leave empty to disable Google login) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
