# ── StudyBuddy Backend — Environment Template ─────────────────────────────────
# Copy this file to .env.dev (development) or .env.prod (production)
# and fill in real values. NEVER commit real .env files to version control.
#
# Generate a secure SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"

ENVIRONMENT=dev

# Database — PostgreSQL async connection string
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/studybuddy

# JWT signing — must be at least 32 random characters, unique per environment
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed frontend origins
# Production example: ALLOWED_ORIGINS=["https://app.yourdomain.com"]
ALLOWED_ORIGINS=["http://localhost:5173"]

# File uploads
UPLOAD_MAX_FILE_SIZE_MB=20
UPLOAD_DIR=uploads

# OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Debug — set to false in production
DEBUG=false
